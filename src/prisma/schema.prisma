generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                 String   @id @db.Uuid
  name               String   @unique
  gender             String
  gender_probability Float
  sample_size        Int
  age                Int
  age_group          String
  country_id         String
  country_probability Float
  created_at         DateTime @default(now()) @db.Timestamptz(6)

  @@map("profiles")
}
